# ── Azure credentials (for Terraform & GitHub Actions) ───────────────────────
# Generate with: az ad sp create-for-rbac --name "cloud-notes-sp" --role Contributor \
#                  --scopes /subscriptions/<SUB_ID> --sdk-auth

ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
